{
  "name": "spotifyunchained",
  "version": "2.0.0",
  "type": "module",
  "private": true,
  "description": "Archive Spotify's New Music Friday playlists before they refresh",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "node --watch --loader newrelic/esm-loader.mjs server/index.js",
    "dev:client": "cd client && bunx vite",
    "build": "cd client && bun install && bun run vite-build",
    "start": "node --loader newrelic/esm-loader.mjs server/index.js"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^7.2.0",
    "mongoose": "^7.8.4",
    "newrelic": "^13.12.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
