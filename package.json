{
  "name": "spotifyunchained",
  "version": "2.0.0",
  "type": "module",
  "private": true,
  "description": "Archive Spotify's New Music Friday playlists before they refresh",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "cd client && bunx vite",
    "build": "cd client && bun install && bun run vite-build",
    "start": "node server/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.2.0",
    "mongoose": "^7.8.9",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "vitest": "^4.1.7"
  }
}
