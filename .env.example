# Required for Spotify Integration
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Database
DB_URI=mongodb://localhost:27017/spotifyunchained

# Server
PORT=3000
NODE_ENV=development

# Optional
SESSION_SECRET=your_session_secret
SKIP_SPOTIFY_SYNC=true

# CORS — comma-separated allowed origins (defaults to 127.0.0.1:4200,127.0.0.1:3000)
ALLOWED_ORIGINS=http://127.0.0.1:4200,http://127.0.0.1:3000

# Token redirect URI validation — comma-separated allowed redirect URIs
ALLOWED_REDIRECT_URIS=http://127.0.0.1:4200/callback,http://127.0.0.1:3000/callback

# New Relic APM
NEW_RELIC_LICENSE_KEY=your_new_relic_license_key
NEW_RELIC_LOG=info

# Google Analytics 4 (configure in client/index.html)
GA_MEASUREMENT_ID=G-4WWQ1NYF17
